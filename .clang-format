# C++ formatter config for firmware/src/**. Based on Google with the repo's
# existing conventions: 4-space indent, attached braces, left-aligned pointers,
# 100-column lines. Run: `git ls-files firmware/src | grep -E '\.(cpp|h|c)$' | xargs .venv-dev/bin/clang-format -i`.
BasedOnStyle: Google
IndentWidth: 4
ColumnLimit: 100
PointerAlignment: Left
AccessModifierOffset: -4
AlignTrailingComments: true
AllowShortFunctionsOnASingleLine: Inline
# Align #define values into a column (restores the repo's original macro style).
AlignConsecutiveMacros: Consecutive
