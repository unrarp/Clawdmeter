# PlatformIO build artifacts (any .pio/ at any depth — incl. firmware/tools/*)
.pio/
firmware/.vscode/

# OS
.DS_Store

# Claude Code — ignore local settings/state, but track shared project rules
.claude/*
!.claude/rules/

# Node tooling deps (npm install --no-save)
tools/node_modules/
tools/package-lock.json

# SVG animation pipeline scratch (rendered wrappers + captured frames)
tools/svg_pipeline/.cache/

# Generated at build time by the splash pre-build hook (firmware/scripts/gen_splash.py)
firmware/src/splash_animations.h

# WiFi/daemon-host secrets — keep local, never commit
firmware/tools/mdns_spike/include/spike_config.h
firmware/src/net_config.h

# Mac daemon venv
daemon/.venv/

# Python bytecode cache
__pycache__/
*.pyc

# Device flash backups (per-unit, ~16MB factory dumps — keep local only)
*-factory-backup.bin
